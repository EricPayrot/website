---
import { siteName } from "../../config/site";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<aside class="nav-rail" aria-label="Site">
  <a class="nav-rail__brand" href="/book">{siteName}</a>
  <nav class="nav-rail__nav" aria-label="Primary">
    <ul class="nav-rail__links">
      <li>
        <a
          href="/book"
          class:list={[{
            "is-active": pathname === "/book" || pathname.startsWith("/book/"),
          }]}
          aria-current={
            pathname === "/book" || pathname.startsWith("/book/")
              ? "page"
              : undefined
          }
          data-astro-prefetch
        >
          Fragments
        </a>
      </li>
      <li>
        <a
          href="/about"
          class:list={[{ "is-active": pathname === "/about" }]}
          aria-current={pathname === "/about" ? "page" : undefined}
          data-astro-prefetch
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class:list={[{ "is-active": pathname === "/contact" }]}
          aria-current={pathname === "/contact" ? "page" : undefined}
          data-astro-prefetch
        >
          Contact
        </a>
      </li>
    </ul>
  </nav>
</aside>

<style>
  .nav-rail {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    padding: var(--space-xl) var(--space-lg);
    border-right: 1px solid var(--color-border);
    background: var(--color-bg);
    min-height: 100%;
  }

  .nav-rail__brand {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-text);
    display: block;
  }

  .nav-rail__brand:visited {
    color: var(--color-text);
  }

  .nav-rail__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .nav-rail__links a {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-text-secondary);
    text-decoration: none;
    display: block;
    padding: var(--space-sm) 0;
  }

  .nav-rail__links a:visited {
    color: var(--color-text-secondary);
  }

  .nav-rail__links a:hover {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .nav-rail__links a.is-active {
    color: var(--color-text);
    font-weight: 700;
  }

  @media (max-width: 767px) {
    .nav-rail {
      padding: var(--space-lg) var(--space-md);
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      min-height: unset;
    }
  }
</style>
