---
import { siteName, socialLinks } from "../../config/site";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<aside class="nav-rail" aria-label="Site">
  <div class="nav-rail__bar">
    <a class="nav-rail__brand" href="/book">{siteName}</a>
    <button
      type="button"
      class="nav-rail__toggle"
      aria-expanded="false"
      aria-controls="nav-rail-panel"
      aria-label="Open menu"
    >
      <svg
        class="nav-rail__toggle-icon"
        viewBox="0 0 24 24"
        width="24"
        height="24"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M4 7h16M4 12h16M4 17h16"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </div>

  <div id="nav-rail-panel" class="nav-rail__panel">
    <nav class="nav-rail__nav" aria-label="Primary">
      <ul class="nav-rail__links">
        <li>
          <a
            href="/book"
            class:list={[{
              "is-active": pathname === "/book" || pathname.startsWith("/book/"),
            }]}
            aria-current={
              pathname === "/book" || pathname.startsWith("/book/")
                ? "page"
                : undefined
            }
            data-astro-prefetch
          >
            Fragments - Book
          </a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[{ "is-active": pathname === "/about" }]}
            aria-current={pathname === "/about" ? "page" : undefined}
            data-astro-prefetch
          >
            About
          </a>
        </li>
        <li>
          <a
            href="/contact"
            class:list={[{ "is-active": pathname === "/contact" }]}
            aria-current={pathname === "/contact" ? "page" : undefined}
            data-astro-prefetch
          >
            Contact
          </a>
        </li>
      </ul>
    </nav>
    <div class="nav-rail__footer">
    <ul class="nav-rail__social" aria-label="Social">
      {
        socialLinks.map((link) => (
          <li>
            <a
              class="nav-rail__social-link"
              href={link.href}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label={`${link.name} (${link.handle})`}
            >
              {link.name === "Instagram" ? (
                <svg
                  class="nav-rail__social-icon"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  aria-hidden="true"
                  focusable="false"
                >
                  <rect
                    x="3"
                    y="3"
                    width="18"
                    height="18"
                    rx="5"
                    ry="5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"></rect>
                  <circle
                    cx="12"
                    cy="12"
                    r="4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"></circle>
                  <circle cx="17.25" cy="6.75" r="1.1" fill="currentColor"></circle>
                </svg>
              ) : (
                <svg
                  class="nav-rail__social-icon"
                  viewBox="0 0 24 24"
                  width="22"
                  height="22"
                  aria-hidden="true"
                  focusable="false"
                >
                  <path
                    d="M14 8h3V5h-3a4 4 0 0 0-4 4v2H8v3h2v7h3v-7h2.5l.5-3H13V9a1 1 0 0 1 1-1Z"
                    fill="currentColor"></path>
                </svg>
              )}
            </a>
          </li>
        ))
      }
    </ul>

    <div
      id="nav-cookie-notice"
      class="nav-rail__cookies is-hidden"
      role="region"
      aria-label="Cookie notice"
    >
      <div class="nav-rail__cookies-inner">
        <p class="nav-rail__cookies-text">This site uses cookies</p>
        <button type="button" class="nav-rail__cookies-btn" data-cookie-dismiss>
          got it
        </button>
      </div>
    </div>
  </div>
  </div>
</aside>

<script>
  const COOKIE_NOTICE_KEY = "cookie-notice-dismissed";
  const MOBILE_NAV_MQ = "(max-width: 767px)";

  function initMobileNav() {
    const rail = document.querySelector<HTMLElement>(".nav-rail");
    const toggle = document.querySelector<HTMLButtonElement>(".nav-rail__toggle");
    const panel = document.getElementById("nav-rail-panel");
    if (!rail || !toggle || !panel || rail.dataset.navInitialized === "true") return;

    rail.dataset.navInitialized = "true";

    const setOpen = (open: boolean) => {
      panel.classList.toggle("is-open", open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };

    const isMobile = () => window.matchMedia(MOBILE_NAV_MQ).matches;

    toggle.addEventListener("click", () => {
      setOpen(!panel.classList.contains("is-open"));
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        if (isMobile()) setOpen(false);
      });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && panel.classList.contains("is-open")) {
        setOpen(false);
        toggle.focus();
      }
    });

    window.matchMedia(MOBILE_NAV_MQ).addEventListener("change", (event) => {
      if (!event.matches) setOpen(false);
    });
  }

  initMobileNav();
  document.addEventListener("astro:page-load", initMobileNav);

  function initCookieNotice() {
    const notice = document.getElementById("nav-cookie-notice");
    const btn = document.querySelector<HTMLButtonElement>("[data-cookie-dismiss]");
    if (!notice || !btn || notice.dataset.initialized === "true") return;

    notice.dataset.initialized = "true";

    if (localStorage.getItem(COOKIE_NOTICE_KEY) === "1") return;

    notice.classList.remove("is-hidden");

    btn.addEventListener("click", () => {
      notice.classList.add("is-dismissing");

      const finish = () => {
        notice.classList.add("is-hidden");
        notice.classList.remove("is-dismissing");
        localStorage.setItem(COOKIE_NOTICE_KEY, "1");
      };

      const inner = notice.querySelector(".nav-rail__cookies-inner");
      if (inner) {
        inner.addEventListener("transitionend", finish, { once: true });
      } else {
        finish();
      }
    });
  }

  initCookieNotice();
  document.addEventListener("astro:page-load", initCookieNotice);
</script>

<style>
  .nav-rail {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
    background: var(--color-bg);
    min-height: 100%;
  }

  .nav-rail__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .nav-rail__panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    flex: 1;
    min-height: 0;
  }

  .nav-rail__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    flex-shrink: 0;
  }

  .nav-rail__toggle:hover {
    background: var(--color-code-bg);
  }

  .nav-rail__toggle:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .nav-rail__toggle-icon {
    display: block;
  }

  .nav-rail__brand {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--color-text);
    display: block;
  }

  .nav-rail__brand:visited {
    color: var(--color-text);
  }

  .nav-rail__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .nav-rail__links a {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--color-text-secondary);
    text-decoration: none;
    display: block;
    padding: var(--space-sm) 0;
  }

  .nav-rail__links a:visited {
    color: var(--color-text-secondary);
  }

  .nav-rail__links a:hover {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .nav-rail__links a.is-active {
    color: var(--color-text);
    font-weight: 700;
  }

  .nav-rail__footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .nav-rail__social {
    list-style: none;
    margin: 0;
    padding: 0;
    padding-inline-start: 0;
    display: flex;
    flex-direction: row;
    gap: var(--space-md);
  }

  .nav-rail__social li {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-rail__social li::marker {
    content: none;
  }

  .nav-rail__social-link,
  .nav-rail__social-link:visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-rail__social-link:hover {
    opacity: 0.75;
  }

  .nav-rail__social-link:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .nav-rail__social-icon {
    display: block;
  }

  .nav-rail__cookies {
    overflow: hidden;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
    max-height: 6rem;
    transition:
      max-height 0.35s ease,
      opacity 0.35s ease,
      padding 0.35s ease,
      border-color 0.35s ease;
  }

  .nav-rail__cookies.is-hidden {
    display: none;
  }

  .nav-rail__cookies.is-dismissing {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    border-top-color: transparent;
  }

  .nav-rail__cookies-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition:
      transform 0.35s ease,
      opacity 0.35s ease;
  }

  .nav-rail__cookies.is-dismissing .nav-rail__cookies-inner {
    transform: translateY(100%);
    opacity: 0;
  }

  .nav-rail__cookies-text {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .nav-rail__cookies-btn {
    align-self: flex-start;
    font: inherit;
    font-size: 0.8125rem;
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-text);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
  }

  .nav-rail__cookies-btn:hover {
    background: var(--color-code-bg);
  }

  @media (max-width: 767px) {
    .nav-rail {
      position: sticky;
      top: 0;
      z-index: 100;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
      min-height: unset;
    }

    .nav-rail__bar {
      padding: var(--space-md);
    }

    .nav-rail__toggle {
      display: inline-flex;
    }

    .nav-rail__panel {
      display: none;
      gap: var(--space-lg);
      padding: 0 var(--space-md) var(--space-lg);
      border-top: 1px solid var(--color-border);
      background: var(--color-bg);
    }

    .nav-rail__panel.is-open {
      display: flex;
    }

    .nav-rail__footer {
      margin-top: 0;
    }
  }

  @media (min-width: 768px) {
    .nav-rail {
      padding: var(--space-xl) var(--space-lg);
      gap: var(--space-xl);
    }

    .nav-rail__bar {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-rail__cookies,
    .nav-rail__cookies-inner {
      transition: none;
    }
  }
</style>
