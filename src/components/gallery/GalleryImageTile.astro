---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  workSlug: string;
  workTitle: string;
  imageIndex: number;
  src: ImageMetadata;
  alt: string;
}

const { workSlug, workTitle, imageIndex, src, alt } = Astro.props;
const href = `/artwork/${workSlug}/${imageIndex}`;
---

<a class="all-img" href={href} data-astro-prefetch>
  <div class="all-img__crop">
    <Image
      src={src}
      alt={alt}
      widths={[200, 400, 600]}
      sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
      loading="lazy"
      class="all-img__img"
    />
  </div>
  <div class="all-img__meta">
    <span class="all-img__title">{workTitle}</span>
  </div>
</a>

<style>
  .all-img {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: color-mix(in oklab, var(--color-bg) 90%, var(--color-border));
    min-height: 44px;
  }

  .all-img:hover,
  .all-img:focus-visible {
    border-color: var(--color-accent);
  }

  .all-img__crop {
    aspect-ratio: 1;
    overflow: hidden;
    background: color-mix(in oklab, var(--color-border) 30%, transparent);
  }

  .all-img__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .all-img__meta {
    padding: var(--space-sm) var(--space-md);
  }

  .all-img__title {
    font-size: 0.88rem;
    color: var(--color-muted);
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
