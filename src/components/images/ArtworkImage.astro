---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  /** Hint to readers / layout; first image on a page may use `priority`. */
  priority?: boolean;
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  priority = false,
  sizes = "(max-width: 768px) 100vw, min(960px, 85vw)",
} = Astro.props;

const loading = priority ? "eager" : "lazy";
const fetchPriority = priority ? "high" : "auto";
---

<figure class="artwork-image">
  <Image
    src={src}
    alt={alt}
    sizes={sizes}
    widths={[480, 960, 1200, 1600]}
    loading={loading}
    decoding="async"
    fetchpriority={fetchPriority}
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
