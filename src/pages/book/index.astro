---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import defaultHero from "../../assets/placeholders/hero-landscape.svg";

const description =
  "New book — browse the cover and interior spreads with an interactive page-flip preview.";

const pagesGlob = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/book/pages/**/*.{jpg,jpeg,png,gif,webp,svg}",
  { eager: true },
);
const heroGlob = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/book/hero.{jpg,jpeg,png,gif,webp,svg}",
  { eager: true },
);

function sortedGlobKeys(record: Record<string, unknown>): string[] {
  return Object.keys(record).sort((a, b) =>
    a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }),
  );
}

function entriesToBookPages(
  record: Record<string, { default: ImageMetadata }>,
  altPrefix: string,
) {
  return sortedGlobKeys(record).map((key, i) => {
    const im = record[key].default;
    return {
      src: im.src,
      alt: `${altPrefix} — page ${i + 1}`,
      pageNumber: i + 1,
    };
  });
}

let bookPages = entriesToBookPages(pagesGlob, "Book");

if (bookPages.length === 0) {
  const ph = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/placeholders/**/*.svg",
    { eager: true },
  );
  bookPages = entriesToBookPages(ph, "Preview").slice(0, 9);
}

const bookPagesJson = JSON.stringify(bookPages);

const heroKeys = sortedGlobKeys(heroGlob);
const heroImage =
  heroKeys.length > 0 ? heroGlob[heroKeys[0]].default : defaultHero;
---

<BaseLayout title="Book" description={description} canonicalPath="/book">
  <h1 class="page-title">Book</h1>

  <p class="book-page__intro lede muted">
    Replace hero and page scans in{" "}
    <code>src/assets/book/</code> (see <code>README.md</code> there). Introduction and publication
    notes go in <code>src/pages/book/index.astro</code>.
  </p>

  <section class="book-page__hero" aria-label="Book cover teaser">
    <div class="book-page__hero-frame">
      <Image
        src={heroImage}
        alt=""
        widths={[640, 960, 1200]}
        sizes="(max-width: 900px) 100vw, min(920px, 85vw)"
        loading="eager"
        decoding="async"
        class="book-page__hero-img"
      />
    </div>
  </section>

  <div class="book-page__body prose">
    <p>
      Use this section for synopsis, imprint, specs, ordering links, related exhibitions, etc.
    </p>
  </div>

  <section class="book-page__gallery" aria-labelledby="book-gallery-heading">
    <h2 id="book-gallery-heading" class="book-page__gallery-title">Browse the book</h2>
    <p class="book-page__gallery-hint muted">
      View uses <strong>A5</strong> proportions (148×210 mm per page): the <strong>cover</strong>
      fills the whole right page; inside spreads show a centred <strong>114×151 mm</strong> image
      area (24 mm below top, 22 mm from the gutter). Turn with the <strong>right / left page</strong>{" "}
      or arrow keys.
    </p>

    <!-- JSON consumed only by `/book` client script -->
    <script
      id="book-flip-data"
      type="application/json"
      set:html={bookPagesJson}
    />

    <div id="book-flip-root" class="book-page__flip-mount"></div>
  </section>
</BaseLayout>

<script>
  import { mountBookFlip } from "../../scripts/interactions/book-flip";

  const root = document.getElementById("book-flip-root");
  const payload = document.getElementById("book-flip-data");
  if (root && payload) {
    try {
      type BookPagePayload = {
        src: string;
        alt: string;
        pageNumber: number;
      };
      const pages = JSON.parse(
        payload.textContent || "[]",
      ) as BookPagePayload[];
      mountBookFlip(root, pages);
    } catch {
      root.innerHTML = "<p>Could not load the book viewer.</p>";
    }
  }
</script>

<style is:global>
  /*
   * A5 portrait: page 148 × 210 mm. Interior frames: 114 × 151 mm, top inset 24 mm,
   * inner edge(s) ↔ spread centre gap 22 mm (→ 12 mm outer margins on spine/fore-edge).
   * Cover on first spread: full-page image on the right only.
   */
  .book-flip-root {
    --bf-radius: var(--radius);
    --bf-gutter-w: 2px;
    --bf-mm-page-w: 148;
    --bf-mm-page-h: 210;
    --bf-mm-frame-w: 114;
    --bf-mm-frame-h: 151;
    --bf-mm-frame-top: 24;
    --bf-mm-from-centre: 22;
    --bf-mm-outer-margin: 12;
    --bf-shadow: 0 12px 40px color-mix(in oklab, var(--color-text) 12%, transparent);
  }

  .book-flip__live {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .book-flip__empty {
    margin: 0;
    padding: var(--space-lg);
    border: 1px dashed var(--color-border);
    border-radius: var(--bf-radius);
    color: var(--color-muted);
  }

  .book-flip__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .book-flip__btn {
    font: inherit;
    font-weight: 600;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--bf-radius);
    border: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-accent) 10%, var(--color-bg));
    color: var(--color-text);
    cursor: pointer;
    min-height: 44px;
  }

  .book-flip__btn:hover:not(:disabled) {
    border-color: var(--color-accent);
  }

  .book-flip__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .book-flip__stage {
    position: relative;
    max-width: calc(840px + var(--bf-gutter-w));
    margin: 0 auto;
    border-radius: var(--bf-radius);
    box-shadow: var(--bf-shadow);
    outline: 1px solid color-mix(in oklab, var(--color-border) 80%, transparent);
    outline-offset: -1px;
    perspective: 1850px;
    transform-style: preserve-3d;
    overflow: visible;
    background: color-mix(in oklab, var(--color-border) 20%, var(--color-bg));
    padding: clamp(10px, 2vw, 18px);
  }

  .book-flip__spread {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
    gap: 0;
  }

  .book-flip__half {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    background: #fff;
  }

  @media (prefers-color-scheme: dark) {
    .book-flip__half {
      background: #f7f7f8;
      color-scheme: light;
    }
  }

  .book-flip__half--inactive {
    pointer-events: none;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, #ffffff 94%, var(--color-border)),
      color-mix(in oklab, #fafafa 100%, transparent)
    );
  }

  .book-flip__half--clickable {
    cursor: pointer;
    transition: outline-color 120ms ease, box-shadow 120ms ease;
  }

  .book-flip__half--clickable:hover {
    box-shadow: inset 0 0 0 999px color-mix(in oklab, var(--color-accent) 6%, transparent);
  }

  .book-flip__half:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -6px;
    z-index: 1;
  }

  .book-flip__gutter {
    align-self: stretch;
    width: var(--bf-gutter-w);
    flex-shrink: 0;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--color-border) 35%, transparent),
      color-mix(in oklab, var(--color-text) 14%, transparent),
      color-mix(in oklab, var(--color-border) 35%, transparent)
    );
  }

  .book-flip__sheet {
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    background: transparent;
    overflow: visible;
  }

  .book-flip__sheet--blank {
    pointer-events: none;
  }

  .book-flip__page-face {
    position: relative;
    width: 100%;
    aspect-ratio: 148 / 210;
    background: #fff;
    box-sizing: border-box;
    flex-shrink: 0;
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-border) 35%, transparent);
  }

  .book-flip__page-face--blank {
    background: linear-gradient(
      140deg,
      color-mix(in oklab, #fafafa 100%, transparent),
      color-mix(in oklab, #eaeaea 92%, transparent)
    );
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--color-border) 25%, transparent);
  }

  .book-flip__frame {
    box-sizing: border-box;
    background: #fff;
  }

  /* Interior frames: identical size on left & right pages (114×151 mm in page coordinates) */
  .book-flip__frame--interior-left {
    position: absolute;
    left: calc(100% * var(--bf-mm-outer-margin) / var(--bf-mm-page-w));
    top: calc(100% * var(--bf-mm-frame-top) / var(--bf-mm-page-h));
    width: calc(100% * var(--bf-mm-frame-w) / var(--bf-mm-page-w));
    height: calc(100% * var(--bf-mm-frame-h) / var(--bf-mm-page-h));
    border: 1px solid color-mix(in oklab, var(--color-border) 55%, transparent);
  }

  .book-flip__frame--interior-right {
    position: absolute;
    left: calc(100% * var(--bf-mm-from-centre) / var(--bf-mm-page-w));
    top: calc(100% * var(--bf-mm-frame-top) / var(--bf-mm-page-h));
    width: calc(100% * var(--bf-mm-frame-w) / var(--bf-mm-page-w));
    height: calc(100% * var(--bf-mm-frame-h) / var(--bf-mm-page-h));
    border: 1px solid color-mix(in oklab, var(--color-border) 55%, transparent);
  }

  .book-flip__frame--cover {
    position: absolute;
    inset: 0;
    border: none;
  }

  .book-flip__img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
    background: #fafafa;
  }

  .book-flip__frame--interior-left .book-flip__img-wrap,
  .book-flip__frame--interior-right .book-flip__img-wrap {
    background: #fff;
  }

  .book-flip__frame--cover .book-flip__img-wrap {
    background: #fff;
  }

  .book-flip__img-wrap img {
    user-select: none;
    vertical-align: middle;
  }

  .book-flip__frame--interior-left .book-flip__img-wrap img,
  .book-flip__frame--interior-right .book-flip__img-wrap img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .book-flip__frame--cover .book-flip__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Page numbers sit in bottom margin (~35 mm below interior frame midline) */
  .book-flip__num {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(100% * 10 / var(--bf-mm-page-h));
    text-align: center;
    margin: 0;
    padding: 0;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: color-mix(in oklab, #333 82%, transparent);
    line-height: 1;
  }

  .book-flip__num--cover {
    bottom: calc(100% * 8 / var(--bf-mm-page-h));
    color: color-mix(in oklab, #222 94%, transparent);
    text-shadow:
      0 0 12px rgb(255 255 255 / 0.75),
      0 1px 2px rgb(255 255 255 / 0.95);
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* Flip leaf overlay */
  .book-flip__leaf {
    position: absolute;
    z-index: 6;
    pointer-events: none;
    transform-style: preserve-3d;
  }

  .book-flip__leaf-inner {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 650ms cubic-bezier(0.45, 0, 0.2, 1);
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, #ffffff 72%, transparent),
      8px 0 24px color-mix(in oklab, #000000 10%, transparent);
    background: transparent;
    backface-visibility: hidden;
  }

  .book-flip__leaf--forward .book-flip__leaf-inner {
    transform-origin: left center;
  }

  .book-flip__leaf--forward.book-flip__leaf--rotating .book-flip__leaf-inner {
    transform: rotateY(-176deg);
  }

  .book-flip__leaf--backward .book-flip__leaf-inner {
    transform-origin: right center;
  }

  .book-flip__leaf--backward.book-flip__leaf--rotating .book-flip__leaf-inner {
    transform: rotateY(176deg);
  }

  .book-flip__leaf-inner .book-flip__sheet {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .book-flip__leaf-inner .book-flip__page-face {
    width: auto;
    height: 100%;
    max-width: 100%;
    aspect-ratio: 148 / 210;
  }

  @media (prefers-reduced-motion: reduce) {
    .book-flip__leaf-inner {
      transition: none;
    }
  }
</style>

<style>
  .book-page__intro code {
    font-size: 0.88em;
  }

  .book-page__hero {
    margin: var(--space-xl) 0;
  }

  .book-page__hero-frame {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow:
      0 16px 40px color-mix(in oklab, var(--color-text) 10%, transparent),
      0 0 0 1px color-mix(in oklab, var(--color-border) 40%, transparent);
    max-height: min(520px, 55vh);
  }

  .book-page__hero-img {
    width: 100%;
    height: 100%;
    max-height: min(520px, 55vh);
    object-fit: cover;
    object-position: center;
    display: block;
    vertical-align: middle;
  }

  .book-page__body {
    margin-bottom: var(--space-xl);
  }

  .book-page__gallery {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .book-page__gallery-title {
    margin: 0 0 var(--space-sm);
    font-size: 1.25rem;
  }

  .book-page__gallery-hint {
    margin: 0 0 var(--space-lg);
    max-width: 38rem;
  }

  .book-page__flip-mount {
    min-height: 8rem;
  }
</style>
