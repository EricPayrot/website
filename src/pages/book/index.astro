---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { artist, siteName } from "../../config/site";
import { workHasFacet } from "../../utils/facets";
import coverImage from "../../assets/works/sheet-linked/couverture/couverture.jpg";
import imgCosmos from "../../assets/works/sheet-linked/img_1291r/IMG_1291R.png";
import imgChance from "../../assets/works/sheet-linked/img_1840r/IMG_1840R.png";
import imgHuman from "../../assets/works/sheet-linked/img_0345r/IMG_0345R.jpg";
import imgProcess from "../../assets/works/sheet-linked/collage_process_buzan/Collage_process_Buzan.jpeg";
import imgEdition from "../../assets/works/sheet-linked/book_in_situ/Book_in_situ.jpeg";

const description =
  "Fragments: Collage of Chance and Order — one hundred collages exploring chaos, balance, and the space between the infinitely small and the infinitely large.";

/** Replace with your order link when ready. */
const buyBookUrl = "#";

const authorName = artist.name === "Your Name" ? siteName : artist.name;

type ContentSection = {
  id: string;
  eyebrow: string;
  title: string;
  paragraphs: string[];
  image: ImageMetadata;
  imageAlt: string;
  reverse?: boolean;
  specs?: string[];
  showCta?: boolean;
};

const contentSections: ContentSection[] = [
  {
    id: "cosmos",
    eyebrow: "Cosmos",
    title: "Fragments of a Larger Whole",
    image: imgCosmos,
    imageAlt: "Collage with horizon, sky, and scattered forms",
    paragraphs: [
      "These collages are made from small pieces, but they speak about large things.",
      "Across the pages appear horizons, oceans, skies, stars, moons, explosions of light and fields of color. Shapes drift through space like planets, comets or particles in motion. A torn edge becomes a coastline. A spray of dots becomes a galaxy.",
      "The collage process itself echoes the story of the universe: separate elements gathering, colliding and finding temporary forms. Piece by piece, a world emerges.",
    ],
  },
  {
    id: "chance-and-order",
    eyebrow: "Chance and Order",
    title: "Two Ways of Looking",
    reverse: true,
    image: imgChance,
    imageAlt: "Paired collage forms suggesting pattern and scatter",
    paragraphs: [
      "Every image in the book is paired with another on a facing page.",
      "Often the same visual language appears in both, but transformed. On one side, shapes float freely, scattered and unpredictable. On the other, they settle into patterns, alignments and structures.",
      "Together, the pairs explore a tension found throughout nature: between randomness and organization, movement and stability, disorder and harmony.",
      "Like crystals forming from chaos, or stars emerging from clouds of dust, order appears without erasing chance.",
    ],
  },
  {
    id: "human-presence",
    eyebrow: "Human Presence",
    title: "Small Figures, Vast Spaces",
    image: imgHuman,
    imageAlt: "Collage with small stick figures in a wide field",
    paragraphs: [
      "Tiny stick figures appear throughout the book.",
      "They are simple marks, almost an afterthought, yet they change the scale of everything around them. Shapes become mountains. Circles become planets. Empty spaces become landscapes waiting to be explored.",
      "These small characters remind us how tiny we are within a much larger universe. Yet they are never overwhelmed by it. They wave, greet one another, raise their arms in celebration.",
      "In a world of constant transformation, they bring a quiet sense of joy and hope.",
    ],
  },
  {
    id: "the-process",
    eyebrow: "The Process",
    title: "One Thousand Attempts",
    reverse: true,
    image: imgProcess,
    imageAlt: "Collage process photograph by Buzan",
    paragraphs: [
      "The project began as a game with rules.",
      "One small format. Three collages every day. One thousand collages over the course of a year.",
      "The materials are humble: papers gathered during travels, magazine fragments, packaging, ink marks, paint, accidental textures. Some pieces are carefully cut, others simply torn by hand.",
      "The process welcomes accidents. Unrelated fragments meet, overlap and suggest unexpected meanings. Through repetition and experimentation, chance gradually reveals connections.",
      "From one thousand collages, one hundred were selected to form this book.",
    ],
  },
  {
    id: "the-book",
    eyebrow: "The Book",
    title: "About the Edition",
    image: imgEdition,
    imageAlt: "Fragments book shown in situ",
    paragraphs: [
      "Fragments: Collage of Chance and Order presents one hundred selected collages reproduced in full color and arranged as fifty visual pairings.",
      "Printed in a carefully designed edition, the book invites readers to move slowly through a sequence of images that shifts between cosmos and landscape, abstraction and storytelling, chaos and balance.",
    ],
    specs: [
      "Self published",
      "111 pages",
      "Price: 25 €",
      "A5 format (15.5 × 21 cm)",
      "ISBN: 979-10-415-8800-8",
    ],
    showCta: true,
  },
];

type BookPageSource = {
  src: ImageMetadata;
  alt: string;
  pageNumber: string;
  sortValue: number;
};

function pageSortValue(page: string | number): number | null {
  const raw = String(page).trim();
  if (!raw) return null;
  if (raw.toLowerCase() === "cover") return 0;

  const n = Number(raw);
  return Number.isFinite(n) ? n : null;
}

const bookWorks = (await getCollection("works", ({ data }) => !data.draft))
  .filter(
    (entry) =>
      workHasFacet(entry, "collections", "collage_book") &&
      entry.data.page != null &&
      String(entry.data.page).trim() !== "",
  )
  .map((entry): BookPageSource | null => {
    const sortValue = pageSortValue(entry.data.page!);
    const image = entry.data.images[0];
    if (sortValue == null || !image) return null;
    const pageNumber = String(entry.data.page).trim();
    return {
      src: image.src,
      alt: image.alt || entry.data.title,
      pageNumber,
      sortValue,
    };
  })
  .filter((page): page is BookPageSource => page != null)
  .sort((a, b) => a.sortValue - b.sortValue);

const bookPages = await Promise.all(
  bookWorks.map(async ({ src, alt, pageNumber }) => {
    const optimized = await getImage({ src, width: 912 });
    return {
      src: optimized.src,
      alt,
      pageNumber,
    };
  }),
);

const bookPagesJson = JSON.stringify(bookPages);
---

<BaseLayout title="Fragments" description={description} canonicalPath="/book">
  <article class="book-page">
    <section class="book-hero book-split" aria-labelledby="book-hero-heading">
      <div class="book-split__copy book-hero__copy">
        <p class="book-hero__label">Fragments</p>
        <h1 id="book-hero-heading" class="book-hero__title">
          Collage of Chance and Order
        </h1>
        <p class="book-hero__lede">
          A book of one hundred collages exploring the space between chaos and balance, chance
          and intention, the infinitely small and the infinitely large.
        </p>
        <p>
          Created from found papers, ink, paint and simple geometric forms, these images drift
          between landscapes, galaxies, oceans and imagined worlds.
        </p>
        <p class="book-hero__byline">By {authorName}</p>
        <p class="book-hero__cta-wrap">
          <a class="book-cta" href={buyBookUrl}>Buy the Book</a>
        </p>
      </div>
      <div class="book-split__media book-hero__media">
        <Image
          src={coverImage}
          alt="Cover of Fragments: Collage of Chance and Order"
          widths={[480, 720, 960, 1200]}
          sizes="(max-width: 768px) 100vw, min(480px, 45vw)"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="book-split__img"
        />
      </div>
    </section>

    {
      contentSections.map((section) => (
        <section
          class:list={["book-split", "book-section", { "book-split--reverse": section.reverse }]}
          id={section.id}
          aria-labelledby={`${section.id}-heading`}
        >
          <div class="book-split__media">
            <Image
              src={section.image}
              alt={section.imageAlt}
              widths={[480, 720, 960]}
              sizes="(max-width: 768px) 100vw, 50vw"
              loading="lazy"
              decoding="async"
              class="book-split__img"
            />
          </div>
          <div class="book-split__copy">
            <p class="book-section__eyebrow">{section.eyebrow}</p>
            <h2 id={`${section.id}-heading`} class="book-section__title">
              {section.title}
            </h2>
            {section.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
            {section.specs && (
              <ul class="book-section__specs">
                {section.specs.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
            {section.showCta && (
              <p class="book-section__cta-wrap">
                <a class="book-cta" href={buyBookUrl}>Buy the Book</a>
              </p>
            )}
          </div>
        </section>
      ))
    }
  </article>

  <section class="book-page__gallery" aria-labelledby="book-gallery-heading">
    <h2 id="book-gallery-heading" class="book-page__gallery-title">Browse the book</h2>
    <p class="book-page__gallery-hint muted">
      View uses <strong>A5</strong> proportions (148×210 mm per page): the <strong>cover</strong>
      fills the whole right page; inside spreads show a centred <strong>114×151 mm</strong> image
      area (24 mm below top, 22 mm from the gutter). Turn with the <strong>right / left page</strong>{" "}
      or arrow keys.
    </p>

    <!-- JSON consumed only by `/book` client script -->
    <script
      id="book-flip-data"
      type="application/json"
      set:html={bookPagesJson}
    />

    <div id="book-flip-root" class="book-page__flip-mount"></div>
  </section>
</BaseLayout>

<script>
  import { mountBookFlip } from "../../scripts/interactions/book-flip";

  const root = document.getElementById("book-flip-root");
  const payload = document.getElementById("book-flip-data");
  if (root && payload) {
    try {
      type BookPagePayload = {
        src: string;
        alt: string;
        pageNumber: string;
      };
      const pages = JSON.parse(
        payload.textContent || "[]",
      ) as BookPagePayload[];
      mountBookFlip(root, pages);
    } catch {
      root.innerHTML = "<p>Could not load the book viewer.</p>";
    }
  }
</script>

<style is:global>
  /*
   * A5 portrait: page 148 × 210 mm. Interior frames are centred at the original
   * 114 × 151 mm position, scaled up 10% to reduce the white margins.
   * inner edge(s) ↔ spread centre gap 22 mm (→ 12 mm outer margins on spine/fore-edge).
   * Cover on first spread: full-page image on the right only.
   */
  .book-flip-root {
    --bf-gutter-w: 2px;
    --bf-mm-page-w: 148;
    --bf-mm-page-h: 210;
    --bf-mm-frame-w: 125.4;
    --bf-mm-frame-h: 166.1;
    --bf-mm-frame-top: 16.45;
    --bf-mm-from-centre: 16.3;
    --bf-mm-outer-margin: 6.3;
  }

  .book-flip__live {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .book-flip__empty {
    margin: 0;
    padding: var(--space-lg);
    border: 1px dashed var(--color-border);
    color: var(--color-muted);
  }

  .book-flip__toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .book-flip__btn {
    font: inherit;
    font-weight: 400;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    min-height: 44px;
  }

  .book-flip__btn:hover:not(:disabled) {
    background: var(--color-code-bg);
  }

  .book-flip__btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .book-flip__stage {
    position: relative;
    max-width: calc(840px + var(--bf-gutter-w));
    margin: 0 auto;
    border: 1px solid var(--color-border);
    perspective: 1850px;
    transform-style: preserve-3d;
    overflow: visible;
    background: var(--color-code-bg);
    padding: clamp(10px, 2vw, 18px);
  }

  .book-flip__spread {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    justify-content: center;
    width: 100%;
    gap: 0;
  }

  /* Pre-rendered next/previous spread (under peeling half; shows through during flip) */
  .book-flip__rear.book-flip__spread {
    z-index: 1;
    pointer-events: none;
  }

  .book-flip__half--rear-passive {
    pointer-events: none !important;
    cursor: default !important;
  }

  .book-flip__half--rear-passive.book-flip__half--clickable:hover {
    box-shadow: none;
  }

  /* Make the peeled column transparent so the rear layer reads through */
  .book-flip__half--peel-slot-forward.book-flip__half--right {
    background: transparent !important;
  }

  .book-flip__half--peel-slot-forward.book-flip__half--right .book-flip__sheet {
    opacity: 0 !important;
  }

  .book-flip__half--peel-slot-back.book-flip__half--left {
    background: transparent !important;
  }

  .book-flip__half--peel-slot-back.book-flip__half--left .book-flip__sheet {
    opacity: 0 !important;
  }

  .book-flip__half {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    background: #fff;
  }

  @media (prefers-color-scheme: dark) {
    .book-flip__half {
      background: #fff;
      color-scheme: light;
    }
  }

  .book-flip__half--inactive {
    pointer-events: none;
    background: #fafafa;
  }

  .book-flip__half--clickable {
    cursor: pointer;
  }

  .book-flip__half--clickable:hover {
    background: #f4f4f4;
  }

  .book-flip__half:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: -6px;
    z-index: 1;
  }

  .book-flip__gutter {
    align-self: stretch;
    width: var(--bf-gutter-w);
    flex-shrink: 0;
    background: var(--color-border);
  }

  .book-flip__sheet {
    width: 100%;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    background: transparent;
    overflow: visible;
  }

  .book-flip__sheet--blank {
    pointer-events: none;
  }

  .book-flip__page-face {
    position: relative;
    width: 100%;
    aspect-ratio: 148 / 210;
    background: #fff;
    box-sizing: border-box;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
  }

  .book-flip__page-face--blank {
    background: #f4f4f4;
    border: 1px solid var(--color-border);
  }

  .book-flip__frame {
    box-sizing: border-box;
    background: #fff;
  }

  /* Interior frames: identical size on left & right pages, centred from the original layout. */
  .book-flip__frame--interior-left {
    position: absolute;
    left: calc(100% * var(--bf-mm-outer-margin) / var(--bf-mm-page-w));
    top: calc(100% * var(--bf-mm-frame-top) / var(--bf-mm-page-h));
    width: calc(100% * var(--bf-mm-frame-w) / var(--bf-mm-page-w));
    height: calc(100% * var(--bf-mm-frame-h) / var(--bf-mm-page-h));
  }

  .book-flip__frame--interior-right {
    position: absolute;
    left: calc(100% * var(--bf-mm-from-centre) / var(--bf-mm-page-w));
    top: calc(100% * var(--bf-mm-frame-top) / var(--bf-mm-page-h));
    width: calc(100% * var(--bf-mm-frame-w) / var(--bf-mm-page-w));
    height: calc(100% * var(--bf-mm-frame-h) / var(--bf-mm-page-h));
  }

  .book-flip__frame--cover {
    position: absolute;
    inset: 0;
    border: none;
    background: transparent;
  }

  .book-flip__img-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
    background: #fafafa;
  }

  .book-flip__frame--interior-left .book-flip__img-wrap,
  .book-flip__frame--interior-right .book-flip__img-wrap {
    background: #fff;
  }

  .book-flip__frame--cover .book-flip__img-wrap {
    position: absolute;
    inset: 0;
    background: #fff;
  }

  .book-flip__img-wrap img {
    user-select: none;
    vertical-align: middle;
  }

  .book-flip__frame--interior-left .book-flip__img-wrap img,
  .book-flip__frame--interior-right .book-flip__img-wrap img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .book-flip__frame--cover .book-flip__img-wrap img {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    display: block;
    object-fit: cover;
  }

  /* Page numbers sit in bottom margin (~35 mm below interior frame midline) */
  .book-flip__num {
    position: absolute;
    left: 0;
    right: 0;
    bottom: calc(100% * 10 / var(--bf-mm-page-h));
    text-align: center;
    margin: 0;
    padding: 0;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.06em;
    color: color-mix(in oklab, #333 82%, transparent);
    line-height: 1;
  }

  .book-flip__num--cover {
    display: none;
  }

  /* Flip leaf overlay */
  .book-flip__leaf {
    position: absolute;
    z-index: 6;
    pointer-events: none;
    transform-style: preserve-3d;
  }

  .book-flip__leaf-inner {
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 650ms cubic-bezier(0.45, 0, 0.2, 1);
    box-shadow:
      inset 0 1px 0 color-mix(in oklab, #ffffff 72%, transparent),
      8px 0 24px color-mix(in oklab, #000000 10%, transparent);
    background: transparent;
    backface-visibility: hidden;
  }

  .book-flip__leaf--forward .book-flip__leaf-inner {
    transform-origin: left center;
  }

  .book-flip__leaf--forward.book-flip__leaf--rotating .book-flip__leaf-inner {
    transform: rotateY(-176deg);
  }

  .book-flip__leaf--backward .book-flip__leaf-inner {
    transform-origin: right center;
  }

  .book-flip__leaf--backward.book-flip__leaf--rotating .book-flip__leaf-inner {
    transform: rotateY(176deg);
  }

  .book-flip__leaf-inner .book-flip__sheet {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .book-flip__leaf-inner .book-flip__page-face {
    width: auto;
    height: 100%;
    max-width: 100%;
    aspect-ratio: 148 / 210;
  }

  @media (prefers-reduced-motion: reduce) {
    .book-flip__leaf-inner {
      transition: none;
    }
  }
</style>

<style>
  :global(main:has(.book-page)) {
    max-width: 72rem;
  }

  .book-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-section);
    margin-bottom: var(--space-section);
  }

  .book-split {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .book-split {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
    }

    .book-split--reverse .book-split__media {
      order: 2;
    }

    .book-split--reverse .book-split__copy {
      order: 1;
    }
  }

  .book-split__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .book-split__copy p {
    margin: 0 0 var(--space-md);
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .book-split__copy p:last-child {
    margin-bottom: 0;
  }

  .book-hero__label {
    margin: 0 0 var(--space-sm);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .book-hero__title {
    margin: 0 0 var(--space-md);
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
  }

  .book-hero__lede {
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  .book-hero__byline {
    margin-top: var(--space-lg) !important;
    color: var(--color-text) !important;
    font-weight: 700;
  }

  .book-hero__cta-wrap,
  .book-section__cta-wrap {
    margin-top: var(--space-lg) !important;
    margin-bottom: 0 !important;
  }

  .book-section__eyebrow {
    margin: 0 0 var(--space-sm);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .book-section__title {
    margin: 0 0 var(--space-md);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-text);
  }

  .book-section__specs {
    margin: var(--space-md) 0 0;
    padding-left: 1.25rem;
    color: var(--color-text-secondary);
  }

  .book-section__specs li {
    margin-bottom: var(--space-xs);
  }

  .book-cta {
    display: inline-block;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-text);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.4;
  }

  .book-cta:hover {
    background: var(--color-code-bg);
    color: var(--color-text);
  }

  .book-cta:visited {
    color: var(--color-text);
  }

  .book-page__gallery {
    margin-top: var(--space-section);
    padding-top: var(--space-section);
    border-top: 1px solid var(--color-border);
  }

  .book-page__gallery-title {
    margin: 0 0 var(--space-sm);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .book-page__gallery-hint {
    margin: 0 0 var(--space-lg);
    max-width: 42rem;
  }

  .book-page__flip-mount {
    min-height: 8rem;
  }
</style>
