---
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ArtworkViewer from "../../../components/artwork/ArtworkViewer.astro";
import { artist, siteUrl } from "../../../config/site";

export async function getStaticPaths() {
  const works = await getCollection("works", ({ data }) => !data.draft);
  return works.flatMap((entry) =>
    entry.data.images.map((_, imageIndex) => ({
      params: { slug: entry.slug, image: String(imageIndex) },
      props: { entry, imageIndex },
    })),
  );
}

const { entry, imageIndex } = Astro.props;

const { Content } = await render(entry);
const img = entry.data.images[imageIndex];
const heroSrc = img.src;
const optimized = await getImage({ src: heroSrc, width: 1200 });
const ogImageUrl = new URL(optimized.src, siteUrl).href;

const pageTitle =
  entry.data.images.length > 1
    ? `${entry.data.title} (${imageIndex + 1}/${entry.data.images.length})`
    : entry.data.title;

const artworkLd = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  name: entry.data.title,
  description: entry.data.description,
  image: ogImageUrl,
  creator: {
    "@type": "Person",
    name: artist.name,
    url: artist.url,
  },
  ...(entry.data.medium ? { artMedium: entry.data.medium } : {}),
  ...(entry.data.year != null ? { dateCreated: String(entry.data.year) } : {}),
};
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description}
  canonicalPath={`/artwork/${entry.slug}/${imageIndex}`}
  ogImage={ogImageUrl}
  jsonLd={artworkLd}
>
  <ArtworkViewer entry={entry} imageIndex={imageIndex}>
    <Content />
  </ArtworkViewer>
</BaseLayout>
