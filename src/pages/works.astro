---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryImageTile from "../components/gallery/GalleryImageTile.astro";
import { buildImageTiles, sortPublishedWorks } from "../utils/gallery-tiles";

const description =
  "Full image gallery across all published works — landscape, portrait, and square placeholders.";

const works = sortPublishedWorks(await getCollection("works"));
const tiles = buildImageTiles(works);
---

<BaseLayout title="Works" description={description} canonicalPath="/works">
  <h1 class="page-title">Works</h1>
  <p class="lede muted">
    Every image from every published work appears below. Select any tile to open the artwork viewer.
  </p>

  <div class="all-images-grid">
    {
      tiles.map((tile) => (
        <GalleryImageTile
          workSlug={tile.workSlug}
          workTitle={tile.workTitle}
          imageIndex={tile.imageIndex}
          src={tile.src}
          alt={tile.alt}
        />
      ))
    }
  </div>
</BaseLayout>
