---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteName, web3formsAccessKey } from "../config/site";

const description =
  "Send a message — inquiries about works, exhibitions, or commissions.";

const accessKey = web3formsAccessKey.trim();
const formReady = accessKey.length > 0;
const mailSubject = `${siteName} — contact form`;

---

<BaseLayout title="Contact" description={description} canonicalPath="/contact">
  <h1 class="page-title">Contact</h1>
  <p class="lede muted">
    I'd love to hear from you. Please send a message using the form below.
  </p>

  {
    !formReady ? (
      <div class="contact__setup prose">
        <p>
          <strong>Form not configured yet.</strong> Add <code>web3formsAccessKey</code> in{" "}
          <code>src/config/site.ts</code> (get a key at{" "}
          <a href="https://web3forms.com">web3forms.com</a>).
        </p>
      </div>
    ) : (
      <>
        <p id="contact-form-status" class="contact__status muted" hidden></p>
        <p id="contact-form-error" class="contact__error" role="alert" hidden></p>
        <div id="contact-form-success" class="contact__success" hidden>
          <h2 class="contact__success-title">Thank you</h2>
          <p>Your message has been sent. I will reply as soon as I can.</p>
        </div>

        <form id="contact-form" class="contact__form">
          <input type="hidden" name="access_key" value={accessKey} />
          <input type="hidden" name="subject" value={mailSubject} />

          {/* Honeypot — Web3Forms discards bots that tick this */}
          <input
            type="checkbox"
            name="botcheck"
            class="contact__honeypot"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />

          <label class="contact__field">
            <span>Name</span>
            <input type="text" name="name" required autocomplete="name" />
          </label>

          <label class="contact__field">
            <span>Email</span>
            <input type="email" name="email" required autocomplete="email" />
          </label>

          <label class="contact__field">
            <span>Message</span>
            <textarea name="message" rows="7" required></textarea>
          </label>

          <button type="submit" class="contact__submit">Send message</button>
        </form>

        <script
          define:vars={{ accessKey, mailSubject }}
          is:inline
        >
          (function () {
            const form = document.getElementById("contact-form");
            const statusEl = document.getElementById("contact-form-status");
            const errEl = document.getElementById("contact-form-error");
            const successEl = document.getElementById("contact-form-success");
            const submitBtn = form?.querySelector('button[type="submit"]');
            if (!form || !statusEl || !errEl || !successEl || !submitBtn) return;

            function showError(msg) {
              errEl.textContent = msg;
              errEl.hidden = false;
              statusEl.hidden = true;
            }

            function clearError() {
              errEl.textContent = "";
              errEl.hidden = true;
            }

            form.addEventListener("submit", async function (e) {
              e.preventDefault();
              clearError();

              const name = String(form.querySelector('[name="name"]')?.value ?? "").trim();
              const email = String(form.querySelector('[name="email"]')?.value ?? "").trim();
              const message = String(form.querySelector('[name="message"]')?.value ?? "").trim();
              const botcheck = form.querySelector('[name="botcheck"]')?.checked;

              const payload = {
                access_key: accessKey,
                subject: mailSubject,
                name,
                email,
                message,
              };
              if (botcheck) payload.botcheck = true;

              submitBtn.disabled = true;
              statusEl.textContent = "Sending…";
              statusEl.hidden = false;

              try {
                const res = await fetch("https://api.web3forms.com/submit", {
                  method: "POST",
                  headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                  },
                  body: JSON.stringify(payload),
                });
                const data = await res.json().catch(function () {
                  return {};
                });

                const ok =
                  res.ok &&
                  (data.success === true ||
                    (typeof data.message === "string" &&
                      data.message.toLowerCase().includes("success")));

                if (!ok) {
                  const msg =
                    (typeof data.message === "string" && data.message) ||
                    (data.body && typeof data.body.message === "string" && data.body.message) ||
                    "Could not send your message. Please try again.";
                  showError(msg);
                  submitBtn.disabled = false;
                  statusEl.hidden = true;
                  return;
                }

                form.hidden = true;
                successEl.hidden = false;
                statusEl.hidden = true;
              } catch {
                showError("Network error. Check your connection and try again.");
                submitBtn.disabled = false;
                statusEl.hidden = true;
              }
            });
          })();
        </script>
      </>
    )
  }
</BaseLayout>

<style>
  .contact__setup {
    margin-top: var(--space-lg);
  }

  .contact__status {
    max-width: 32rem;
    margin: 0 0 var(--space-md);
  }

  .contact__error {
    max-width: 32rem;
    margin: 0 0 var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    background: var(--color-code-bg);
    color: var(--color-text);
    font-size: 0.98rem;
  }

  .contact__success {
    max-width: 32rem;
    margin-top: var(--space-xl);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    background: var(--color-code-bg);
  }

  .contact__success-title {
    margin: 0 0 var(--space-sm);
    font-size: 1.125rem;
    font-weight: 700;
  }

  .contact__success p {
    margin: 0;
    color: var(--color-muted);
  }

  .contact__setup pre {
    margin: var(--space-md) 0;
    padding: var(--space-md) var(--space-lg);
    overflow: auto;
    border: 1px solid var(--color-code-border);
    background: var(--color-code-bg);
    font-size: 0.875rem;
  }

  .contact__form {
    max-width: 32rem;
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .contact__field span {
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .contact__field input,
  .contact__field textarea {
    font: inherit;
    color: var(--color-text);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    width: 100%;
    resize: vertical;
    min-height: 44px;
  }

  .contact__field textarea {
    min-height: 8rem;
  }

  .contact__submit {
    font: inherit;
    font-weight: 400;
    cursor: pointer;
    align-self: flex-start;
    padding: var(--space-sm) var(--space-xl);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
  }

  .contact__submit:hover {
    background: var(--color-code-bg);
  }

  .contact__submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }
</style>
