---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { labelForCollectionSlug } from "../../config/facet-labels";
import { allFacetSlugs, filterWorksByFacet } from "../../utils/facets";
import { buildImageTiles, sortPublishedWorks } from "../../utils/gallery-tiles";

const works = sortPublishedWorks(await getCollection("works"));
const slugs = allFacetSlugs(works, "collections");

const items = slugs.map((slug) => {
  const inCollection = filterWorksByFacet(works, "collections", slug);
  return {
    slug,
    label: labelForCollectionSlug(slug),
    workCount: inCollection.length,
    imageCount: buildImageTiles(inCollection).length,
  };
});

const description =
  "Smart albums: each page lists every image from works that carry the matching collection tag in frontmatter.";
---

<BaseLayout
  title="Collections"
  description={description}
  canonicalPath="/collections"
>
  <h1 class="page-title">Collections</h1>
  <p class="lede muted">
    Tags are authored under <code>facets.collections</code> in each work’s Markdown. A work can appear
    in multiple collections; collection pages are generated automatically from the tags you use.
  </p>

  {
    items.length === 0 ? (
      <div class="muted">
        No collection tags yet. Add a block like the following to any work’s frontmatter:
        <pre class="collections-sample">
{`facets:
  collections:
    - studio-samples
    - archive`}
        </pre>
      </div>
    ) : (
      <ul class="collection-list">
        {items.map((item) => (
          <li class="collection-list__item">
            <a class="collection-list__link" href={`/collections/${item.slug}`} data-astro-prefetch>
              <span class="collection-list__title">{item.label}</span>
              <span class="collection-list__meta muted">
                {item.workCount} work{item.workCount === 1 ? "" : "s"} · {item.imageCount} image
                {item.imageCount === 1 ? "" : "s"}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<style>
  code {
    font-size: 0.9em;
  }

  .collections-sample {
    margin: var(--space-md) 0 0;
    padding: var(--space-md);
    font-size: 0.85rem;
    line-height: 1.45;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: color-mix(in oklab, var(--color-border) 12%, var(--color-bg));
    overflow-x: auto;
  }

  .collection-list {
    list-style: none;
    margin: var(--space-xl) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .collection-list__link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    min-height: 44px;
    background: color-mix(in oklab, var(--color-bg) 88%, var(--color-border));
  }

  .collection-list__link:hover,
  .collection-list__link:focus-visible {
    border-color: var(--color-accent);
  }

  .collection-list__title {
    font-weight: 600;
    font-size: 1.1rem;
  }

  .collection-list__meta {
    font-size: 0.9rem;
  }
</style>
