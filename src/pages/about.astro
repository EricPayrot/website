---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artist } from "../config/site";

const description =
  `About ${artist.name} — biography, practice, and background.`;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: artist.name,
  url: artist.url,
  ...(artist.sameAs.length ? { sameAs: artist.sameAs } : {}),
};
---

<BaseLayout
  title="About"
  description={description}
  canonicalPath="/about"
  jsonLd={personLd}
>
  <h1 class="page-title">About</h1>
  <p class="lede muted">
    A short biography and notes on your practice. Edit this page in{" "}
    <code>src/pages/about.astro</code>.
  </p>

  <div class="about prose">
    <p>
      Replace this paragraph with where you live and work, your background, or what drew you to
      your current medium.
    </p>
    <p>
      Add another paragraph on themes in your work, recent exhibitions or residencies, or how you
      describe your studio process—the kind of bio visitors expect on an artist portfolio.
    </p>
    <p>
      Update your name and site-wide links in <code>src/config/site.ts</code> (<code
        >artist.name</code
      >,
      <code>sameAs</code> for social or gallery profiles).
    </p>
  </div>
</BaseLayout>

<style>
  .about {
    margin-top: var(--space-xl);
  }

  .about code {
    font-size: 0.88em;
  }
</style>
