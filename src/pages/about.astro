---
import BaseLayout from "../layouts/BaseLayout.astro";
import { artist } from "../config/site";

const description =
  `About ${artist.name} — biography, practice, and background.`;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: artist.name,
  url: artist.url,
  ...(artist.sameAs.length ? { sameAs: artist.sameAs } : {}),
};
---

<BaseLayout
  title="About"
  description={description}
  canonicalPath="/about"
  jsonLd={personLd}
>
  <h1 class="page-title">About</h1>
  <div class="about prose">
    <p>
      For over forty years, I have explored painting and visual art through original works on canvas and paper. This book marks my first venture into publishing.
    </p>
    <p>
      Created over the course of a year of daily practice, it follows a simple but demanding creative process: one theme, a small format, and collage as a tool for discovery.
    </p>
    <p>
    More than a collection of images, the book is conceived as an artwork in itself—a space where each collage connects with the next, creating a visual conversation that remains open to interpretation and imagination.
    </p>
  </div>
</BaseLayout>

<style>
  .about {
    margin-top: var(--space-xl);
  }

  .about code {
    font-size: 0.88em;
  }
</style>
