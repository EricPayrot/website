---
import BaseLayout from "../../layouts/BaseLayout.astro";

const description = "Thank you — your message was received.";
---

<BaseLayout
  title="Message sent"
  description={description}
  canonicalPath="/contact/thanks"
  noindex={true}
>
  <h1 class="page-title">Thank you</h1>
  <p class="lede">
    Your message has been sent. I will reply when I can.
  </p>
  <p class="muted">
    Continue browsing using the navigation on the left.
  </p>
</BaseLayout>
